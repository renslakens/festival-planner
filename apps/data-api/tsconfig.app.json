{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "rootDir": "../../",
    "rootDirs": ["../../"]
  },
  "include": ["src/**/*.ts", "../../libs/**/*.ts"],
  "exclude": [
    "../../libs/frontend/**/*",
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts",
    "jest.config.ts"
  ]
}
